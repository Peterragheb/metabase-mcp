{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "src/worker.ts",
    "src/google-handler.ts",
    "src/cloudflare-bindings.ts",
    "src/oauth-upstream-utils.ts",
    "src/workers-oauth-utils.ts"
  ]
}
